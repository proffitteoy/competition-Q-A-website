      "y": 960,
      "width": 280,
      "height": 150,
      "color": "3"
    },
    {
      "id": "n19",
      "type": "text",
      "text": "Insights\\n\\n- competition is the public and workflow aggregate root\\n- form_version separates current config from historical submissions\\n- registration serves query, revision and audit serve traceability",
      "x": 1080,
      "y": 20,
      "width": 360,
      "height": 180,
      "color": "1"
    }
