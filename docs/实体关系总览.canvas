      "y": 960,
      "width": 300,
      "height": 150,
      "color": "3"
    },
    {
      "id": "n18",
      "type": "text",
      "text": "**registration_audit_log**\\nreview trail\\n\\n- action\\n- from -> to\\n- operator",
