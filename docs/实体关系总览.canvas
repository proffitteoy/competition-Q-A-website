      "y": 860,
      "width": 260,
      "height": 80,
      "color": "3"
    },
    {
      "id": "n15",
      "type": "text",
      "text": "**registration**\\ncurrent effective record\\n\\n- applicant_user_id\\n- status\\n- payload_json\\n- applicant_snapshot_json\\n- revision_no",
      "x": 40,
      "y": 960,
      "width": 320,
      "height": 180,
      "color": "3"
    },
    {
      "id": "n16",
      "type": "text",
      "text": "**registration_team_member**\\nteam member current value\\n\\n- leader flag\\n- member_payload_json",
      "x": 400,
      "y": 960,
      "width": 280,
      "height": 140,
      "color": "3"
    },
    {
      "id": "n17",
      "type": "text",
      "text": "**registration_revision**\\nrevision snapshot\\n\\n- payload snapshot\\n- applicant snapshot\\n- team snapshot",
